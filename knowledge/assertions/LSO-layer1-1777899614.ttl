cmo:ConcertHall a owl:Class ;
    rdfs:label "Concert hall"@en ;
    rdfs:comment "A specific auditorium or performance space, typically contained within a venue. Address is inherited from the containing venue."@en ;
    rdfs:subClassOf schema:Place .

cmo:instrumentalist-identity a owl:Class ;
    rdfs:label "Instrumentalist identity"@en ;
    rdfs:comment "A musical identity of a person who plays an instrument, such as pianist or violinist."@en ;
    rdfs:subClassOf cmo:musical-identity .

cmo:voice-range a owl:Class ;
    rdfs:label "Voice range"@en ;
    rdfs:comment "A vocal musical identity categorised by voice type, such as soprano, tenor, or bass."@en ;
    rdfs:subClassOf cmo:musical-identity .

