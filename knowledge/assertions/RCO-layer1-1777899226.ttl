        cmk:concertgebouw-amsterdam-1778469300,
        cmk:palais-des-beaux-arts-brussels-1778547600 ;
    cmo:known-as-a cmk:conductor .

cmk:sol-gabetta a foaf:Person ;
    foaf:familyName "Gabetta" ;
    foaf:firstName "Sol" ;
    cmo:known-as-a cmk:cellist ;
    cmo:performs-in cmk:concertgebouw-amsterdam-1778296500,
        cmk:concertgebouw-amsterdam-1778469300,
        cmk:palais-des-beaux-arts-brussels-1778547600 .

<https://knowledge.semanticscore.net/ontology> a owl:Ontology ;
    owl:imports mo:,
        foaf: .

cmo:acronym a owl:DatatypeProperty ;
    rdfs:label "acronym"@en ;
    rdfs:comment "A short identifying code or abbreviation for an organisation, used for file naming and display."@en ;
    rdfs:domain schema:Organization ;
    rdfs:range xsd:string .

cmo:conducts-in a owl:ObjectProperty ;
    rdfs:label "conducts in"@en ;
    rdfs:comment "Connects a conductor to a performance they conduct."@en ;
    rdfs:subPropertyOf cmo:performs-in .

cmo:contains-music-by a owl:ObjectProperty ;
    rdfs:label "contains music by"@en ;
    rdfs:comment "Connects a concert programme to the composers of the musical works it contains."@en ;
    rdfs:domain cmo:Programme ;
    rdfs:range schema:Person .

cmo:ensemble-identity a owl:Class ;
    rdfs:label "Ensemble identity"@en ;
    rdfs:comment "A musical identity of a person who performs as part of an ensemble."@en ;
    rdfs:subClassOf cmo:musical-identity .

cmo:is-performed-at a owl:ObjectProperty ;
    rdfs:label "is performed at"@en ;
    rdfs:comment "Connects a concert programme to the performance event at which it is performed."@en ;
    rdfs:domain cmo:Programme ;
    rdfs:range mo:Performance .

cmo:known-as-a a owl:ObjectProperty ;
    rdfs:label "known as a"@en ;
    rdfs:comment "Connects a person to the musical identity or role they are known for, such as conductor or pianist."@en ;
    rdfs:domain foaf:Agent ;
    rdfs:range cmo:musical-identity .

cmo:musical-content a owl:DatatypeProperty ;
    rdfs:label "musical content"@en ;
    rdfs:comment "The musical content of a programme performed at a performance, represented as a string of text."@en ;
    rdfs:domain mo:Programme ;
    rdfs:range xsd:string .

cmo:narrates-in a owl:ObjectProperty ;
    rdfs:label "narrates in"@en ;
    rdfs:comment "Connects a narrator to a performance in which they narrate."@en ;
    rdfs:subPropertyOf cmo:performs-in .

cmo:plays-in a owl:ObjectProperty ;
    rdfs:label "plays in"@en ;
    rdfs:comment "Connects an instrumentalist to a performance in which they play."@en ;
    rdfs:subPropertyOf cmo:performs-in .

cmo:sings-in a owl:ObjectProperty ;
    rdfs:label "sings in"@en ;
    rdfs:comment "Connects a singer to a performance in which they sing."@en ;
    rdfs:subPropertyOf cmo:performs-in .

cmo:voice-range a owl:Class ;
    rdfs:label "Voice range"@en ;
    rdfs:comment "A vocal musical identity categorised by voice type, such as soprano, tenor, or bass."@en ;
    rdfs:subClassOf cmo:musical-identity .

cmk:cellist a cmo:instrumentalist-identity ;
    schema:name "Cellist" .

