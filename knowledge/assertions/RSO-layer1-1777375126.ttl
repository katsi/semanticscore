cmo:ConcertHall a owl:Class ;
    rdfs:label "Concert hall"@en ;
    rdfs:comment "A specific auditorium or performance space, typically contained within a venue. Address is inherited from the containing venue."@en ;
    rdfs:subClassOf schema:Place .

cmk:conductor a cmo:musical-identity .

cmk:the-helsinki-music-centre-paavo-hall-1748714400 a mo:Performance ;
    schema:location cmk:paavo-hall ;
    schema:name "Chamber Music Concert: Primitive Force" ;
    schema:organizer cmk:finnish-radio-symphony-orchestra ;
    schema:startDate "2026-05-24T15:00:00"^^xsd:dateTime ;
    schema:url "https://yle.fi/aihe/a/20-10008701"^^xsd:anyURI .

cmo:performs-in a owl:ObjectProperty ;
    rdfs:label "performs in"@en ;
    rdfs:comment "Connects a person to a performance in which they participate in any musical role. Super-property of all role-specific participation properties."@en .

cmo:voice-range a owl:Class ;
    rdfs:label "Voice range"@en ;
    rdfs:comment "A vocal musical identity categorised by voice type, such as soprano, tenor, or bass."@en ;
    rdfs:subClassOf cmo:musical-identity .

cmo:musical-identity a owl:Class ;
    rdfs:label "Musical identity"@en ;
    rdfs:comment "The musical role or identity of a person, such as conductor, singer, or instrumentalist."@en .

