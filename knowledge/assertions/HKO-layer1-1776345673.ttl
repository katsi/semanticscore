cmk:trombonist a cmo:instrumentalist-identity .

cmk:trumpeter a cmo:instrumentalist-identity .

cmk:violist a cmo:instrumentalist-identity .

cmk:vocalist a cmo:musical-identity .

cmo:Programme a owl:Class ;
    rdfs:label "Programme"@en ;
    rdfs:comment "A concert programme listing the musical works to be performed at a performance."@en .

cmo:voice-range a owl:Class ;
    rdfs:label "Voice range"@en ;
    rdfs:comment "A vocal musical identity categorised by voice type, such as soprano, tenor, or bass."@en ;
    rdfs:subClassOf cmo:musical-identity .

